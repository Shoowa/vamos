[Unit]
Description=Add a credential to OpenBao
Requires=dev_openbao.service
After=dev_openbao.service

[Service]
Type=oneshot
Restart=on-failure
RestartSec=5
RemainAfterExit=yes
ExecStart=/usr/bin/sleep 5
ExecStart=/usr/bin/curl -H "X-Vault-Token: token" \
    -H "Content-Type: application/json" \
    --request POST --data '{"data": {"password": "password"}}' \
    http://localhost:8200/v1/secret/data/dev-postgres-test
ExecStart=/usr/bin/curl -H "X-Vault-Token: token" \
    -H "Content-Type: application/json" \
    --request POST --data '{"data": {"password": "ReDiS4LiFe"}}' \
    http://localhost:8200/v1/secret/data/dev-redis-test
